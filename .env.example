# Configuração do agent worker (Hetzner box). Copie para .env e ajuste.
# NUNCA commite o .env real.

# Endereço de escuta do HTTP.
AGENT_ADDR=:8080

# Bearer token que o control plane usa para autenticar (OBRIGATÓRIO).
# Gere um valor forte, ex.: openssl rand -hex 32
AGENT_TOKEN=

# Host que entra na connection URL devolvida ao control plane.
# Local: 127.0.0.1. Produção: IP da rede privada (WireGuard) da box.
AGENT_ADVERTISE_HOST=127.0.0.1

# IP onde a porta do container Postgres é publicada no host.
# Local: 127.0.0.1. Produção: IP da rede privada.
AGENT_BIND_HOST=127.0.0.1

# Modo SSL da connection URL. Local: disable. Produção: require.
AGENT_SSLMODE=disable

# Versão default do Postgres quando o request não especifica.
AGENT_DEFAULT_PG_VERSION=16

# Binário do Docker.
AGENT_DOCKER_BIN=docker

# Range [start,end] de portas de host alocadas por tenant. Cada container recebe
# uma porta FIXA do range no create (gravada em label), estável através de
# stop/start → a DATABASE_URL não fica stale após suspend/resume. Precisa ficar
# livre no firewall só para a rede privada. (1 ≤ start ≤ end ≤ 65535)
AGENT_PORT_RANGE_START=20000
AGENT_PORT_RANGE_END=29999
